# Copy to .env and fill in real values. .env is gitignored — never commit it.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=placeholder
SNAPTRADE_CLIENT_ID=placeholder
SNAPTRADE_CONSUMER_KEY=placeholder
# Theta Terminal v3 reads this from the environment (dashboard -> API key).
# v2 used email/password via a creds file; v3 prefers the key.
THETADATA_API_KEY=placeholder
ANTHROPIC_API_KEY=placeholder
TELEGRAM_BOT_TOKEN=placeholder
TELEGRAM_CHAT_ID=placeholder
